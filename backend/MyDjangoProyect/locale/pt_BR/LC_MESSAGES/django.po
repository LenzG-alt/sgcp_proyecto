# --- Serializers ---
msgid "Contrasena del usuario (minimo 6 caracteres). Solo al crear."
msgstr "Senha do usuario (minimo 6 caracteres). Apenas ao criar."

msgid "El estilista seleccionado no existe o no esta disponible."
msgstr "O estilista selecionado nao existe ou nao esta disponivel."

msgid "El servicio seleccionado no existe."
msgstr "O servico selecionado nao existe."

msgid "No se pueden crear citas en fechas pasadas."
msgstr "Nao e possivel criar agendamentos em datas passadas."

